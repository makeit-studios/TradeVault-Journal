# Production (Vercel)
DATABASE_URL="postgresql://user:password@host:5432/db"
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-with: openssl rand -hex 32"
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

